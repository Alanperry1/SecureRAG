# Copy to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=securerag
TOP_K=5

# ── Security Thresholds ───────────────────────────────────────────────────────
INJECTION_ENTROPY_THRESHOLD=4.5
INJECTION_SCORE_THRESHOLD=0.6
COSINE_OUTLIER_Z_THRESHOLD=2.0
POISON_SCORE_THRESHOLD=0.65
ANOMALY_RECON_THRESHOLD=0.015
CONFIDENCE_THRESHOLD=0.70
MIN_SUPPORTING_CHUNKS=2

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL_SECONDS=3600
REDIS_ENABLED=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
